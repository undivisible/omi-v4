# All four model tiers are OpenRouter slugs, so the completions endpoint must
# be OpenRouter and the key an OpenRouter key. Point MIMO_CHAT_COMPLETIONS_URL
# at OpenRouter and put the OpenRouter key in MIMO_API_KEY (the var names are
# historical — they are just "the OpenAI-compatible endpoint + key").
MIMO_API_KEY=your-openrouter-api-key-here
MIMO_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions
GEMINI_API_KEY=your-gemini-api-key-here
# Model-tier routing (single source of truth: worker/src/model-tiers.ts,
# app/native/hub/src/model_tier.rs). Each tier is env-overridable; leave unset
# to use the default shown. BALANCED falls back to MIMO_MODEL when unset. The
# defaults are OpenRouter slugs (provider-prefixed) and only resolve against
# the OpenRouter endpoint above.
#   speed      latency-sensitive live insights/answers  default inception/mercury-2
#   balanced   meeting notes + general chat (default)   default xiaomi/mimo-v2.5
#   smart      hard reasoning                           default xiaomi/mimo-v2.5-pro
#   multimodal vision / visual computer-use             default google/gemini-3.6-flash
#   search     web-grounded answers (live search)      default perplexity/sonar
# OMI_MODEL_SPEED=inception/mercury-2
# OMI_MODEL_BALANCED=xiaomi/mimo-v2.5
# OMI_MODEL_SMART=xiaomi/mimo-v2.5-pro
# OMI_MODEL_MULTIMODAL=google/gemini-3.6-flash
# OMI_MODEL_SEARCH=perplexity/sonar
OPENAI_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
XAI_OAUTH_CLIENT_ID=your-xai-oauth-client-id-here
OAUTH_TOKEN_KEY=base64-encoded-32-byte-key-here
DEV_FAKE_PRO=true
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here
# Dev/testing only: enables the ChatGPT/xAI OAuth broker + proxy routes,
# which relay subscription-auth sign-in and traffic for personal interactive
# use. Leave unset (or "false") everywhere except local dev/testing --
# these routes are not meant to run in production.
ENABLE_DEV_OAUTH_BROKER=true
# Better Stack observability. Every var is optional — leave any unset and that
# path no-ops (nothing installed, no overhead). See docs/ai-and-observability.md §5.
# Error tracking (Sentry-compatible): the DSN from Better Stack → Error tracking →
# your source. SENTRY_DSN is accepted as a fallback name.
# BETTERSTACK_SENTRY_DSN=your-betterstack-sentry-compatible-dsn-here
# Logs export: HTTP/OTel source URL + token from Better Stack → Logs → source.
# BETTERSTACK_LOGS_URL=your-betterstack-logs-ingest-url-here
# BETTERSTACK_LOGS_TOKEN=your-betterstack-logs-source-token-here
# Uptime heartbeat: the POST URL of a Better Stack heartbeat monitor; the cron
# pings it on a successful run so a missed beat alerts.
# BETTERSTACK_HEARTBEAT_URL=your-betterstack-heartbeat-url-here
